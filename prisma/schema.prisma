generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Ekta sample User model
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String?  @unique
  image     String?
  credits   Int      @default(5) // Free user der jonno initial 5 credits
  createdAt DateTime @default(now())
}